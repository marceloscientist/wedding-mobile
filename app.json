{
  "expo": {
    "name": "casaki-mobile",
    "slug": "casaki-mobile",
    "version": "0.0.1",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-asset"],
    "scheme": "casaki"
  }
}
